---
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import Features from './Features.astro';
import HowItWorks from './HowItWorks.astro';
import Pricing from './Pricing.astro';
import FAQ from './FAQ.astro';
import { useTranslations } from '../i18n/ui';

export interface Props {
  lang: 'en' | 'id';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const repoUrl = "https://github.com/Telconation/PARKIN";
---
<Navbar lang={lang} />
  
<main class="bg-surface-bg transition-colors duration-500">
  <Hero lang={lang} />

  <!-- S3: Social Proof / Stats Bar -->
  <section class="py-20 bg-surface-card border-y border-surface-border transition-colors duration-500">
    <div class="max-w-7xl mx-auto px-4 scroll-reveal">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center divide-y md:divide-y-0 md:divide-x divide-surface-border">
        <div class="pt-4 md:pt-0">
          <p class="font-display text-4xl font-black text-brand-primary-light mb-1">0</p>
          <p class="text-surface-muted text-sm font-bold uppercase tracking-widest">{t('stats.cost')}</p>
        </div>
        <div class="pt-8 md:pt-0">
          <p class="font-display text-4xl font-black text-surface-text mb-1">&gt; 500</p>
          <p class="text-surface-muted text-sm font-bold uppercase tracking-widest">{t('stats.slots')}</p>
        </div>
        <div class="pt-8 md:pt-0">
          <p class="font-display text-4xl font-black text-status-ok mb-1">&lt; 100ms</p>
          <p class="text-surface-muted text-sm font-bold uppercase tracking-widest">{t('stats.latency')}</p>
        </div>
      </div>
    </div>
  </section>

  <Features lang={lang} />
  <HowItWorks lang={lang} />

  <!-- S7: Segmen Pengguna Tabs -->
  <section class="py-24 px-4 bg-surface-bg border-t border-surface-border transition-colors duration-500">
      <div class="max-w-5xl mx-auto scroll-reveal text-center">
          <h2 class="font-display text-3xl font-bold text-surface-text mb-10">{t('segment.title')}</h2>
          
          <div class="flex flex-wrap justify-center gap-4 mb-8" id="segment-tabs">
              <button class="px-6 py-2 rounded-full border border-brand-primary font-bold text-sm text-brand-primary bg-brand-primary/10 tab-btn active" data-target="sekolah">{t('segment.btn.school')}</button>
              <button class="px-6 py-2 rounded-full border border-surface-border font-bold text-sm text-surface-muted hover:text-surface-text tab-btn" data-target="komersial">{t('segment.btn.commercial')}</button>
              <button class="px-6 py-2 rounded-full border border-surface-border font-bold text-sm text-surface-muted hover:text-surface-text tab-btn" data-target="enterprise">{t('segment.btn.enterprise')}</button>
          </div>

          <div class="glass p-8 md:p-12 rounded-3xl text-left bg-gradient-to-br from-surface-card to-surface-bg border border-surface-border shadow-md transition-colors duration-500">
              <div id="sekolah" class="tab-pane">
                  <h3 class="font-display font-bold text-2xl text-surface-text mb-3">{t('segment.school.title')}</h3>
                  <p class="text-surface-muted mb-6">{t('segment.school.desc')}</p>
              </div>
              <div id="komersial" class="tab-pane hidden">
                  <h3 class="font-display font-bold text-2xl text-surface-text mb-3">{t('segment.commercial.title')}</h3>
                  <p class="text-surface-muted mb-6">{t('segment.commercial.desc')}</p>
              </div>
              <div id="enterprise" class="tab-pane hidden">
                  <h3 class="font-display font-bold text-2xl text-surface-text mb-3">{t('segment.enterprise.title')}</h3>
                  <p class="text-surface-muted mb-6">{t('segment.enterprise.desc')}</p>
              </div>
          </div>
      </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const btns = document.querySelectorAll('.tab-btn');
      const panes = document.querySelectorAll('.tab-pane');

      btns.forEach(btn => {
          btn.addEventListener('click', (e) => {
              const target = (e.currentTarget as HTMLButtonElement).getAttribute('data-target');
              
              btns.forEach(b => {
                  b.classList.remove('border-brand-primary', 'text-brand-primary', 'bg-brand-primary/10');
                  b.classList.add('border-surface-border', 'text-surface-muted');
              });
              panes.forEach(p => p.classList.add('hidden'));

              (e.currentTarget as HTMLButtonElement).classList.remove('border-surface-border', 'text-surface-muted');
              (e.currentTarget as HTMLButtonElement).classList.add('border-brand-primary', 'text-brand-primary', 'bg-brand-primary/10');
              
              document.getElementById(target!)?.classList.remove('hidden');
          });
      });
    });
  </script>

  <!-- NOTE: Compare Table (S8) HAS BEEN REMOVED PER USER PLAN -->

  <!-- S9: Trust Signals -->
  <section class="py-12 bg-surface-bg border-y border-surface-border transition-colors duration-500">
      <div class="max-w-6xl mx-auto px-4 flex flex-wrap justify-between items-center gap-6 opacity-80 mix-blend-luminosity dark:mix-blend-normal saturate-0 hover:saturate-100 transition-all duration-700">
          <span class="flex items-center gap-3 font-mono text-xs sm:text-sm font-bold text-surface-text whitespace-nowrap"><i class="fa-solid fa-microchip text-lg"></i> {t('trust.yolo')}</span>
          <span class="flex items-center gap-3 font-mono text-xs sm:text-sm font-bold text-surface-text whitespace-nowrap"><i class="fa-solid fa-mobile-screen-button text-lg"></i> {t('trust.pwa')}</span>
          <span class="flex items-center gap-3 font-mono text-xs sm:text-sm font-bold text-surface-text whitespace-nowrap"><i class="fa-solid fa-lock text-lg"></i> {t('trust.https')}</span>
          <a href={repoUrl} target="_blank" class="flex items-center gap-3 font-mono text-xs sm:text-sm font-bold text-surface-text hover:text-brand-primary transition-colors whitespace-nowrap"><i class="fa-solid fa-code text-lg"></i> {t('trust.os')}</a>
      </div>
  </section>

  <Pricing lang={lang} />
  <FAQ lang={lang} />

  <!-- S12: Final CTA Banner -->
  <section class="py-24 px-4 bg-gradient-brand relative overflow-hidden">
      <!-- Dot grid overlay -->
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMDUiLz4KPC9zdmc+')] opacity-20 mask-image:linear-gradient(to_bottom,black,transparent)"></div>
      <div class="max-w-4xl mx-auto text-center relative z-10 scroll-reveal">
          <h2 class="font-display text-4xl sm:text-5xl font-black text-white mb-6">{t('cta.title')}</h2>
          <p class="text-white/90 text-lg mb-10 max-w-2xl mx-auto font-medium">{t('cta.desc')}</p>
          <a href="https://wa.me/6281212932426" target="_blank" class="inline-flex items-center gap-3 px-8 py-4 rounded-xl text-lg font-bold text-slate-800 bg-white hover:bg-gray-100 shadow-2xl hover:scale-105 transition-all">
             <i class="fa-brands fa-whatsapp text-2xl text-green-500"></i>
             {t('cta.btn')}
          </a>
      </div>
  </section>

  <!-- S13: Footer -->
  <footer class="bg-surface-bg border-t border-surface-border text-surface-muted py-12 px-4 transition-colors duration-500">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center md:items-start gap-8">
          <div class="text-center md:text-left flex-1">
              <div class="w-8 h-8 rounded bg-gradient-brand flex items-center justify-center mb-4 mx-auto md:mx-0 overflow-hidden p-[2px]">
                  <img src="/images/icons/maskable_icon_x96.png" alt="Logo" class="w-full h-full object-contain filter invert mix-blend-screen opacity-90" />
              </div>
              <h4 class="text-surface-text font-bold mb-2">PARKIN &mdash; {t('footer.slogan')}</h4>
              <p class="text-xs max-w-sm">{t('trust.os')} System.<br/>Built for scale natively on Edge technologies.</p>
          </div>
          <div class="flex flex-col text-center md:text-right text-sm">
              <a href="#fitur" class="hover:text-surface-text mb-2">{t('nav.fitur')}</a>
              <a href="#pricing" class="hover:text-surface-text mb-2">{t('nav.pricing')}</a>
              <a href="#faq" class="hover:text-surface-text mb-2">{t('nav.faq')}</a>
              <a href={repoUrl} target="_blank" class="hover:text-brand-primary mt-2 font-bold"><i class="fa-brands fa-github"></i> Source Code</a>
          </div>
      </div>
      <div class="max-w-7xl mx-auto mt-12 pt-6 border-t border-surface-border flex flex-col sm:flex-row justify-between items-center text-xs opacity-60">
          <p>&copy; {t('footer.copyright')}</p>
          <p>Made with &hearts; for the Open Source Community.</p>
      </div>
  </footer>
</main>
