---
import { useTranslations } from '../i18n/ui';

export interface Props {
  lang: 'en' | 'id';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const demoUrl = "https://dashboard.parkin.my.id";
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden flex flex-col items-center justify-center text-center px-4" id="home">
    
  <!-- Gradient Mesh Decoration -->
  <div class="absolute inset-0 pointer-events-none -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-primary/10 via-surface-bg to-surface-bg transition-colors duration-500"></div>

  <div class="max-w-4xl mx-auto space-y-8 animate-slide-up">
    <!-- H1 SEO Target -->
    <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-surface-text leading-tight tracking-tight">
      {t('hero.title')}
    </h1>

    <!-- Sub-hero -->
    <p class="text-base sm:text-lg text-surface-muted max-w-2xl mx-auto font-sans leading-relaxed">
      {t('hero.subtitle')}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={demoUrl} class="w-full sm:w-auto px-8 py-3.5 rounded-xl font-bold text-white bg-brand-primary hover:bg-brand-primary-light shadow-glow-blue transition-all border border-brand-primary-light/50">
        {t('hero.ctaPrimary')}
      </a>
      <a href="#fitur" class="w-full sm:w-auto px-8 py-3.5 rounded-xl font-bold text-surface-text bg-surface-card hover:bg-surface-border/50 border border-surface-border transition-all shadow-sm">
        {t('hero.ctaSecondary')}
      </a>
    </div>
  </div>

  <!-- Hero Dashboard Mockup utilizing real screenshot -->
  <div class="max-w-5xl mx-auto mt-16 sm:mt-24 rounded-2xl overflow-hidden glass hover:shadow-glow-blue transition-all duration-700 animate-fade-in relative z-10 w-full p-2 bg-surface-card border border-surface-border shadow-2xl animate-float" style="animation-delay: 0.2s">
    <div class="rounded-xl overflow-hidden relative">
      <img src="/images/screenshots/Macbook-Air.webp" alt="Dashboard PARKIN Monitoring AI" class="w-full h-auto object-cover" />
       <!-- Floating Mockup CSS Overlay -->
        <div class="absolute bottom-4 right-4 sm:bottom-10 sm:right-10 bg-surface-card/90 backdrop-blur border border-surface-border p-4 rounded-xl shadow-2xl hidden md:block">
             <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-status-ok animate-pulse"></span>
                <span class="text-status-ok text-xs font-bold tracking-wider uppercase">{t('hero.badge')}</span>
             </div>
             <p class="text-surface-muted text-[10px] font-bold uppercase tracking-wider mb-1">{t('hero.car')}</p>
             <div class="text-2xl font-black text-surface-text flex items-baseline gap-1">
                 <span class="counter-mobil">45</span> <span class="text-xs font-normal text-surface-muted">/100</span>
             </div>
        </div>
    </div>
  </div>

</section>

<style>
  @property --num {
    syntax: "<integer>";
    initial-value: 0;
    inherits: false;
  }
  .counter-mobil {
    counter-reset: num var(--num);
    animation: countmobil 3s ease-out forwards;
  }
  .counter-mobil::after { content: counter(num); }
  @keyframes countmobil { from { --num: 0; } to { --num: 45; } }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
