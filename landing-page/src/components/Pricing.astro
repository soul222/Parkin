---
import { useTranslations } from '../i18n/ui';

export interface Props {
  lang: 'en' | 'id';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section id="pricing" class="py-20 px-4 bg-surface-bg border-t border-surface-card transition-colors duration-500">
    <div class="max-w-7xl mx-auto scroll-reveal">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-surface-text mb-4">{t('pricing.title')}</h2>
        <p class="text-surface-muted">{t('pricing.desc')}</p>
      </div>
  
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        
        <!-- PRO TIER -->
        <div class="glass bg-surface-card border border-surface-border p-8 rounded-2xl flex flex-col items-center text-center border-t-4 border-t-brand-primary shadow-sm hover:shadow-glow-blue transition-all">
          <h3 class="font-display text-2xl font-bold text-surface-text mb-2">{t('pricing.pro.title')}</h3>
          <p class="text-surface-muted text-sm mb-8 h-10">{t('pricing.pro.desc')}</p>
          
          <a href="https://wa.me/6281212932426?text=Halo tim PARKIN, saya tertarik dengan paket PRO. Bisakah kita menjadwalkan demo?" target="_blank" class="w-full mb-8 py-3 rounded-xl font-bold text-surface-text bg-surface-bg border border-surface-border hover:bg-brand-primary/10 transition-all shadow-sm">
            {t('pricing.pro.btn')}
          </a>
  
          <ul class="text-left space-y-4 w-full text-surface-muted text-sm border-t border-surface-border pt-6">
            <li class="flex items-center gap-3">
              <i class="fa-solid fa-check text-status-ok"></i>
              <span>{t('pricing.pro.l1')}</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fa-solid fa-check text-status-ok"></i>
              <span>{t('pricing.pro.l2')}</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fa-solid fa-check text-status-ok"></i>
              <span>{t('pricing.pro.l3')}</span>
            </li>
            <li class="flex items-center gap-3">
               <i class="fa-solid fa-check text-status-ok"></i>
               <span>{t('pricing.pro.l4')}</span>
             </li>
            <li class="flex items-center gap-3 opacity-40">
              <i class="fa-solid fa-xmark text-status-danger"></i>
              <span>{t('pricing.pro.l5')}</span>
            </li>
          </ul>
        </div>
  
        <!-- ENTERPRISE TIER -->
        <div class="glass bg-surface-card border border-surface-border p-8 rounded-2xl flex flex-col items-center text-center border-t-4 border-t-brand-secondary relative transform md:-translate-y-4 shadow-glow-green hover:shadow-2xl transition-all">
          <div class="absolute -top-3 px-3 py-1 bg-brand-secondary text-[10px] font-bold tracking-widest uppercase text-white rounded-full">Solusi Total</div>
          <h3 class="font-display text-2xl font-bold text-surface-text mb-2">{t('pricing.ent.title')}</h3>
          <p class="text-surface-muted text-sm mb-8 h-10">{t('pricing.ent.desc')}</p>
          
          <a href="https://wa.me/6281212932426?text=Halo tim PARKIN, saya tertarik berbisnis dengan paket ENTERPRISE." target="_blank" class="w-full mb-8 py-3 rounded-xl font-bold text-white bg-brand-secondary hover:bg-brand-secondary border border-brand-secondary/50 shadow-glow-green shadow-sm transition-all">
            {t('pricing.ent.btn')}
          </a>
  
          <ul class="text-left space-y-4 w-full text-surface-muted text-sm border-t border-surface-border pt-6">
            <li class="flex items-center gap-3 text-surface-text">
              <i class="fa-solid fa-check text-brand-secondary"></i>
              <span class="font-semibold">{t('pricing.ent.l1')}</span>
            </li>
             <li class="flex items-center gap-3">
              <i class="fa-solid fa-check text-status-ok"></i>
              <span>{t('pricing.ent.l2')}</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fa-solid fa-check text-status-ok"></i>
              <span>{t('pricing.ent.l3')}</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fa-solid fa-check text-status-ok"></i>
              <span>{t('pricing.ent.l4')}</span>
            </li>
            <li class="flex items-center gap-3">
             <i class="fa-solid fa-check text-status-ok"></i>
              <span>{t('pricing.ent.l5')}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
